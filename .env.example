# Supabase — public values, exposed to the browser.
# Get these from the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — server-side only. Used by the path-item coaching feature
# (src/lib/coaching.ts). Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Resend — server-side only. Used by the in-app "Invite a colleague"
# action (src/lib/invite.ts). Same key used for Resend SMTP — get it
# from https://resend.com/api-keys.
RESEND_API_KEY=
